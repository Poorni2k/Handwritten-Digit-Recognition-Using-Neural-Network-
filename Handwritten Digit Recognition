# ============================================================
# 🧠 HANDWRITTEN DIGIT RECOGNITION USING NEURAL NETWORK (Keras)
# ============================================================

# Step 1️⃣: Import necessary libraries
import numpy as np
import matplotlib.pyplot as plt
import tensorflow as tf
from tensorflow import keras
from tensorflow.keras import layers

# Optional: Prevent interactive blocking issues (especially on Windows)
import matplotlib
matplotlib.use('TkAgg')

# Step 2️⃣: Load MNIST dataset
(X_train, y_train), (X_test, y_test) = keras.datasets.mnist.load_data()

print("Training data shape:", X_train.shape)
print("Testing data shape:", X_test.shape)

# Step 3️⃣: Visualize sample training images (non-blocking)
plt.figure(figsize=(8,8))
for i in range(9):
    plt.subplot(3,3,i+1)
    plt.imshow(X_train[i], cmap='gray')
    plt.title(f"Label: {y_train[i]}")
    plt.axis('off')
plt.suptitle("Sample Images from MNIST Dataset", fontsize=16)
plt.tight_layout()
plt.show(block=False)
plt.pause(3)
plt.close()

# Step 4️⃣: Preprocess data (normalize values 0–1)
X_train = X_train / 255.0
X_test = X_test / 255.0

# Step 5️⃣: Build a simple neural network model
model = keras.Sequential([
    layers.Flatten(input_shape=(28, 28)),   # convert 2D → 1D
    layers.Dense(128, activation='relu'),   # hidden layer
    layers.Dropout(0.2),                    # prevent overfitting
    layers.Dense(10, activation='softmax')  # output layer (10 digits)
])

# Step 6️⃣: Compile model
model.compile(optimizer='adam',
            loss='sparse_categorical_crossentropy',
            metrics=['accuracy'])

# Step 7️⃣: Train model with validation split
history = model.fit(X_train, y_train, epochs=5, validation_split=0.1)

# Step 8️⃣: Evaluate model on test data
test_loss, test_acc = model.evaluate(X_test, y_test, verbose=2)
print("\n✅ Test Accuracy:", test_acc)

# Step 9️⃣: Plot Accuracy & Loss Graphs (auto-close)
plt.figure(figsize=(10,5))

# Accuracy Plot
plt.subplot(1,2,1)
plt.plot(history.history['accuracy'], label='Training Accuracy', marker='o')
plt.plot(history.history['val_accuracy'], label='Validation Accuracy', marker='o')
plt.title('Model Accuracy')
plt.xlabel('Epoch')
plt.ylabel('Accuracy')
plt.legend()

# Loss Plot
plt.subplot(1,2,2)
plt.plot(history.history['loss'], label='Training Loss', marker='o')
plt.plot(history.history['val_loss'], label='Validation Loss', marker='o')
plt.title('Model Loss')
plt.xlabel('Epoch')
plt.ylabel('Loss')
plt.legend()

plt.tight_layout()
plt.savefig("training_results.png")  # saves the graph
plt.show(block=False)
plt.pause(3)
plt.close()

# Step 🔟: Predict some test samples
predictions = model.predict(X_test)

# Step 1️⃣1️⃣: Show multiple predictions with actual values
plt.figure(figsize=(10,10))
for i in range(9):
    plt.subplot(3,3,i+1)
    plt.imshow(X_test[i], cmap='gray')
    plt.title(f"Predicted: {np.argmax(predictions[i])}\nActual: {y_test[i]}")
    plt.axis('off')
plt.suptitle("Predictions vs Actual Labels", fontsize=16)
plt.tight_layout()
plt.savefig("predictions_grid.png")
plt.show(block=False)
plt.pause(3)
plt.close()

# Step 1️⃣2️⃣: Display single random prediction result clearly
index = np.random.randint(0, len(X_test))
plt.imshow(X_test[index], cmap='gray')
plt.title(f"Predicted: {np.argmax(predictions[index])}, Actual: {y_test[index]}")
plt.axis('off')
plt.savefig("single_prediction.png")
plt.show(block=False)
plt.pause(3)
plt.close()

print("\n✅ All tasks completed successfully! Plots saved in current folder.")
